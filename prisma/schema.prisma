generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String   @default("Admin")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model StoreSetting {
  id               String   @id @default(cuid())
  storeName        String   @default("Toko Online")
  storeSlug        String   @unique @default("toko")
  logoUrl          String?
  whatsappNumber   String   @default("6281234567890")
  address          String   @default("Jl. Contoh No. 123")
  operatingHours   String   @default("08:00 - 21:00")
  shippingPerKm    Float    @default(5000)
  themeColor       String   @default("#10b981")
  instagram        String?
  facebook         String?
  tiktok           String?
  bankAccount      String?
  bankName         String?
  bankHolder       String?
  isOpen           Boolean  @default(true)
  storeLatitude    Float?
  storeLongitude   Float?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Category {
  id        String   @id @default(cuid())
  name      String
  icon      String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  products  Product[]
}

model Banner {
  id        String   @id @default(cuid())
  imageUrl  String
  title     String?
  subtitle  String?
  link      String?
  sortOrder Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id              String   @id @default(cuid())
  name            String
  slug            String   @unique
  description     String?
  categoryId      String?
  category        Category?  @relation(fields: [categoryId], references: [id])
  sku             String?
  basePrice       Float    @default(0)
  sellPrice       Float    @default(0)
  discountPrice   Float?
  discountPercent Int?
  stock           Int      @default(0)
  minStock        Int      @default(5)
  images          String   @default("[]")
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  orderItems      OrderItem[]
  stockMovements  StockMovement[]
  favorites       Favorite[]
}

model Order {
  id              String   @id @default(cuid())
  orderNumber     String   @unique
  customerName    String
  customerPhone   String
  customerAddress String?
  deliveryMethod  String   @default("pickup")
  shippingCost    Float    @default(0)
  shippingDistance Float?
  subtotal        Float    @default(0)
  totalDiscount   Float    @default(0)
  total           Float    @default(0)
  status          String   @default("pending")
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  orderItems      OrderItem[]
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  name      String
  price     Float
  quantity  Int
  discount  Float   @default(0)
  subtotal  Float
}

model StockMovement {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  type      String   @default("in")
  quantity  Int      @default(0)
  note      String?
  createdAt DateTime @default(now())
}

model FinanceRecord {
  id          String   @id @default(cuid())
  type        String   @default("income")
  category    String?
  amount      Float    @default(0)
  description String?
  date        DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Favorite {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  sessionId String
  createdAt DateTime @default(now())

  @@unique([productId, sessionId])
}
